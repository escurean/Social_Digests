PORT=3001
NODE_ENV=development

DATABASE_URL=postgresql://social_digests:social_digests_dev@localhost:5432/social_digests
REDIS_URL=redis://localhost:6379

# Access token lifetime (keep short — 15m recommended)
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://api.socialdigests.com/api/donations/mpesa/callback

SENDGRID_API_KEY=
EMAIL_FROM=no-reply@socialdigests.com

FRONTEND_URL=http://localhost:5173

# Optional — leave blank to disable Sentry
SENTRY_DSN=

# REQUIRED — Google OAuth will return 500 if unset (FIX #3: no longer optional)
GOOGLE_CLIENT_ID=
